{
	"name": "@credets/backend",
	"version": "1.0.0",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"clean": "rm -rf dist && echo 'Done.'",
		"dev": "bun run --watch --no-clear-screen --console-depth 10 index.ts",
		"build": "bun build index.ts --outdir ./dist",
		"start": "bun run dist/index.js",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"date-fns": "^4.1.0",
		"iron-webcrypto": "^2.0.0"
	},
	"devDependencies": {
		"@credets/shared-types": "workspace:*",
		"@credets/shared-utils": "workspace:*",
		"typescript": "catalog:"
	}
}
